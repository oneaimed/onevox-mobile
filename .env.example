# OneVox - variaveis de ambiente (EXEMPLO). Copie para .env e preencha.
# .env e gitignored. Em producao, setar no painel da Vercel.
# NUNCA comitar chaves.

# --- Supabase (backend: service role bypassa RLS) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=onevox-audios

# --- Supabase (frontend: publico, protegido por RLS) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- IA / voz (backend) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
ELEVENLABS_API_KEY=

# --- Sessao do app (assina o cookie app_session_id) ---
JWT_SECRET=

# Obs.: as variaveis do Manus (OAUTH_SERVER_URL, VITE_APP_ID, BUILT_IN_FORGE_*)
# e do MySQL (DATABASE_URL) serao removidas na migracao.
